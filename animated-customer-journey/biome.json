{
    "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
    "formatter": {
        "indentStyle": "tab",
        "indentWidth": 2,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "semicolons": "always",
            "quoteStyle": "double"
        }
    }
}